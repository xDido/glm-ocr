# ============================================================================
# GLM-OCR two-container load-test harness — all knobs
# Copy to `.env`, tune, then `make up`.
# ============================================================================

# ---- CPU container (glmocr.server behind gunicorn) -------------------------

# Inbound HTTP fan-out (process-level × thread-level).
# Total inbound concurrency = CPU_WORKERS * CPU_THREADS.
CPU_WORKERS=4
CPU_THREADS=16

# Hard kill for stuck workers (seconds). Must exceed OCR_REQUEST_TIMEOUT.
GUNICORN_TIMEOUT=480

# Port the CPU container listens on (host + container).
GLMOCR_PORT=5002

# Intra-request outbound fan-out: how many region crops glmocr sends to
# SGLang in parallel for a single document. This is the "number of threads"
# for the OCR pipeline itself.
OCR_MAX_WORKERS=32

# SGLang call timeouts (seconds).
OCR_CONNECT_TIMEOUT=10
OCR_REQUEST_TIMEOUT=60

# Retry policy for 429/5xx from SGLang.
OCR_RETRY_MAX=1
OCR_RETRY_BACKOFF_BASE=0.5
OCR_RETRY_BACKOFF_MAX=8

# HTTP connection pool. Must be >= CPU_THREADS * OCR_MAX_WORKERS
# or you'll get pool-exhaustion 503s masquerading as SGLang failures.
OCR_CONN_POOL=2048

# Thread caps for torch CPU kernels (layout inference). Default is
# host-core-count (8 here) per process; with CPU_WORKERS=4 that's
# 4×8=32 math threads fighting the 8-vCPU cgroup limit. Setting to
# 2 gives CPU_WORKERS × OMP_NUM_THREADS = 4×2 = 8 which matches the
# cgroup exactly when all workers are simultaneously in layout.
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1

# Layout detection (PP-DocLayoutV3). Set to false to skip and send whole
# pages to SGLang. Keep device=cpu so GPU stays free for SGLang.
LAYOUT_ENABLED=true
LAYOUT_DEVICE=cpu
LAYOUT_USE_POLYGON=false
# Stage 2: ONNX Runtime backend (export on first boot, runs via ORT).
LAYOUT_BACKEND=onnx
LAYOUT_ONNX_THREADS=1
# Optional torch.compile pass on the layout model. Measured regression on
# this 4-worker × 8-gthread CPU setup (per-call mean +19%, p95 +18%, 2%
# fail rate from recompile-triggered timeouts). Leave off.
LAYOUT_COMPILE=false
# Cross-request layout coalescer. Measured ~5x rps uplift on the 2-worker
# setup (omnidoc-20260421-200758 vs omnidoc-20260421-191156: c=12 0.35 ->
# 1.74 rps; c=24 0.31 -> 1.69; c=32 0.33 -> 1.68). Requires CPU_THREADS=12
# + OCR_CONN_POOL=384 to feed the coalescer. BATCH_MAX=8 did not help
# (marginal regression at c=32); keep at 4. Earlier note claimed a
# regression at 4 workers; that setup oversubscribed CPU and doesn't
# apply here.
LAYOUT_BATCH_ENABLED=true
LAYOUT_BATCH_MAX=4
LAYOUT_BATCH_WINDOW_MS=20

# Where the CPU container finds SGLang. In docker-compose this is the
# service name; for ECS it's the Cloud Map DNS name.
SGLANG_HOST=sglang
SGLANG_PORT=30000
SGLANG_SCHEME=http

# Model name sent in /v1/chat/completions body. Must match
# SGL_SERVED_MODEL_NAME below.
OCR_MODEL_NAME=glm-ocr

# ---- GPU container (SGLang serving zai-org/GLM-OCR) ------------------------

# Tag of the lmsysorg/sglang image to run. `latest` tracks the current stable
# release on Docker Hub. Pin to a specific version (e.g. v0.5.10.post1) for
# reproducibility.
SGL_IMAGE_TAG=latest

SGL_MODEL_PATH=zai-org/GLM-OCR
SGL_SERVED_MODEL_NAME=glm-ocr
SGL_TP_SIZE=1
SGL_DTYPE=float16

# Batching / scheduling. Tune against CPU_WORKERS*CPU_THREADS*OCR_MAX_WORKERS.
SGL_MAX_RUNNING_REQUESTS=64
SGL_MAX_PREFILL_TOKENS=8192
SGL_MAX_TOTAL_TOKENS=200000
SGL_MEM_FRACTION_STATIC=0.95

# Per-request sequence-length ceiling (prompt + generation). Default
# when unset = the model-card's max (131,072 for GLM-OCR) which is
# ~15x what an OCR region actually uses. Dropping it lets SGLang free
# per-slot page-table memory and grow `sglang:max_total_num_tokens`.
#
# CEILING CONSTRAINT: glmocr sends `max_tokens=8192` per region call
# (glmocr/config.py:151 default). SGLang enforces STRICTLY
# `prompt_tokens + max_tokens <= context_length` and returns HTTP 400
# on violation. Observed prompt sizes go up to ~240 tokens so we need
# at least 8432. Using 16384 (matches SGL_MAX_PREFILL_TOKENS) gives
# a comfortable margin and still frees substantial VRAM vs the
# model-card default of 131,072.
SGL_CONTEXT_LENGTH=24576

SGL_CHUNKED_PREFILL=true
# Chunk size in tokens (only used when SGL_CHUNKED_PREFILL=true).
SGL_CHUNKED_PREFILL_SIZE=8192
SGL_SCHEDULE_POLICY=lpm

# Speculative decoding (NEXTN/MTP heads shipped in GLM-OCR). Swept in
# Stage A. Sub-knobs default in docker/gpu/entrypoint.sh when unset.
SGL_SPECULATIVE=true
SGL_SPEC_ALGORITHM=NEXTN
SGL_SPEC_NUM_STEPS=3
SGL_SPEC_EAGLE_TOPK=1
SGL_SPEC_NUM_DRAFT_TOKENS=4

# ---- Grafana Cloud (remote_write from local Prometheus) -------------------
# Token pasted 2026-04-17 — ROTATE after smoke test confirms the pipe works.
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-65-prod-eu-west-2.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_URL_READ=https://prometheus-prod-65-prod-eu-west-2.grafana.net/api/prom
GRAFANA_CLOUD_PROM_USER=3124240
GRAFANA_CLOUD_PROM_TOKEN=glc_REDACTED

# Grafana Cloud MCP (service account token for dido.grafana.net)
GRAFANA_URL=https://dido.grafana.net
GRAFANA_SA_TOKEN=glsa_REDACTED
