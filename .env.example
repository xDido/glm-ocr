# ============================================================================
# GLM-OCR two-container load-test harness — all knobs
# Copy to `.env`, tune, then `make up`.
# ============================================================================

# ---- CPU container (glmocr.server behind gunicorn) -------------------------

# Inbound HTTP fan-out (process-level × thread-level).
# Total inbound concurrency = CPU_WORKERS * CPU_THREADS.
CPU_WORKERS=2
CPU_THREADS=8

# Hard kill for stuck workers (seconds). Must exceed OCR_REQUEST_TIMEOUT.
GUNICORN_TIMEOUT=180

# Port the CPU container listens on (host + container).
GLMOCR_PORT=5002

# Intra-request outbound fan-out: how many region crops glmocr sends to
# SGLang in parallel for a single document. This is the "number of threads"
# for the OCR pipeline itself.
OCR_MAX_WORKERS=8

# SGLang call timeouts (seconds).
OCR_CONNECT_TIMEOUT=10
OCR_REQUEST_TIMEOUT=120

# Retry policy for 429/5xx from SGLang.
OCR_RETRY_MAX=3
OCR_RETRY_BACKOFF_BASE=0.5
OCR_RETRY_BACKOFF_MAX=8

# HTTP connection pool. Must be >= CPU_THREADS * OCR_MAX_WORKERS
# or you'll get pool-exhaustion 503s masquerading as SGLang failures.
OCR_CONN_POOL=128

# Layout detection (PP-DocLayoutV3). Set to false to skip and send whole
# pages to SGLang. Keep device=cpu so GPU stays free for SGLang.
LAYOUT_ENABLED=true
LAYOUT_DEVICE=cpu
LAYOUT_USE_POLYGON=false
# PP-DocLayoutV3 weights. HF model id or local path. First boot downloads
# ~300 MB into hf-cache/ (same bind mount sglang uses).
LAYOUT_MODEL_DIR=PaddlePaddle/PP-DocLayoutV3_safetensors

# Where the CPU container finds SGLang. In docker-compose this is the
# service name; for ECS it's the Cloud Map DNS name.
SGLANG_HOST=sglang
SGLANG_PORT=30000
SGLANG_SCHEME=http

# Model name sent in /v1/chat/completions body. Must match
# SGL_SERVED_MODEL_NAME below.
OCR_MODEL_NAME=glm-ocr

# ---- GPU container (SGLang serving zai-org/GLM-OCR) ------------------------

# Tag of the lmsysorg/sglang image to run. `latest` tracks the current stable
# release on Docker Hub. Pin to a specific version (e.g. v0.5.10.post1) for
# reproducibility.
SGL_IMAGE_TAG=latest

SGL_MODEL_PATH=zai-org/GLM-OCR
SGL_SERVED_MODEL_NAME=glm-ocr
SGL_TP_SIZE=1
SGL_DTYPE=float16

# Batching / scheduling. Tune against CPU_WORKERS*CPU_THREADS*OCR_MAX_WORKERS.
SGL_MAX_RUNNING_REQUESTS=16
SGL_MAX_PREFILL_TOKENS=16384
SGL_MAX_TOTAL_TOKENS=100000
SGL_MEM_FRACTION_STATIC=0.88
SGL_CHUNKED_PREFILL=true
# Chunk size in tokens (only used when SGL_CHUNKED_PREFILL=true).
SGL_CHUNKED_PREFILL_SIZE=8192
SGL_SCHEDULE_POLICY=lpm

# Host port the sglang container publishes on (the container always listens
# on 30000 internally). Change if 30000 is already in use on your host.
SGL_PORT=30000

# Optional — only if you need a gated HF model.
HF_TOKEN=

# ---- Observability (Prometheus + Grafana) ---------------------------------

# Prometheus scrapes sglang:30000/metrics + cpu:5002/metrics every 5s.
PROMETHEUS_PORT=9090

# Grafana is provisioned with a Prometheus datasource and a "GLM-OCR Load
# Test" dashboard. Log in at http://localhost:$GRAFANA_PORT with user
# "admin" and this password.
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Driver-side metrics stack:
#   - Pushgateway receives the asyncio bench summary at end of run.
#   - locust_exporter scrapes Locust's web UI (below) during the run.
#   - k6 remote-writes straight to Prometheus (which has the receiver
#     enabled).
PUSHGATEWAY_PORT=9091
LOCUST_WEB_PORT=8089

# Container + GPU observability.
CADVISOR_PORT=8088
GPU_EXPORTER_PORT=9835

# ---- Grafana Cloud via Alloy (optional) ----------------------------------
#
# If these three are set, the Alloy container scrapes the same targets as
# local Prometheus and remote_writes them to Grafana Cloud Mimir. Leave
# empty to stay local-only (Alloy will still start but its remote_write
# queue will be empty). Sign up at grafana.com (free tier = 10k active
# series / 14-day retention), then in the portal:
#
#   Connections -> Prometheus -> "Send metrics via Prometheus"
#     (pick "Grafana Alloy" — the block you copy has url/username/password)
#
# The token needs role "MetricsPublisher". Only metrics matching the
# allowlist in docker/alloy/config.alloy are shipped, so free-tier
# cardinality stays comfortable.
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_PROM_TOKEN=

# Read URL for the SAME Cloud Prometheus — consumed by local Grafana's
# provisioned "Prometheus (Cloud)" datasource. It's the above URL with the
# trailing /push stripped (e.g. .../api/prom instead of .../api/prom/push).
# Paste from the Cloud portal's "Configure Grafana data source" section.
GRAFANA_CLOUD_PROM_URL_READ=

# Alloy's built-in UI (scrape target health + remote_write queue).
ALLOY_PORT=12345

# ---- OmniDocBench load test -----------------------------------------------

# Seconds each driver (asyncio, locust, k6) runs for inside `make omnidoc-load`.
OMNIDOC_DURATION=120

# How many random images to pick from datasets/OmniDocBench/ to form the
# per-request pool. Each request samples one image from this pool.
OMNIDOC_SAMPLE_POOL=64

# ---- Load-test orchestrator (scripts/loadtest_omnidoc.sh) -----------------

# Where the orchestrator annotates runs and posts driver metrics. Only
# change these if you've remapped PROMETHEUS_PORT / GRAFANA_PORT /
# PUSHGATEWAY_PORT above.
PROMETHEUS_URL=http://localhost:9090
PUSHGATEWAY_URL=http://localhost:9091
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin

# ---- AWS --------------------------------------------------------------------

# Leave ECS_ENDPOINT empty to target real AWS (defaults to the real ECS
# endpoint for the region). Set it only if you're pointing register-tasks.sh
# at a custom endpoint.
ECS_ENDPOINT=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
