FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
      PYTHONUNBUFFERED=1 \
      PIP_NO_CACHE_DIR=1 \
      PIP_DISABLE_PIP_VERSION_CHECK=1

# System deps:
#   poppler-utils  -> PDF rendering fallback for glmocr
#   libgl1 / libglib2.0-0 -> opencv runtime libs
#   gettext-base   -> envsubst
#   curl           -> healthcheck
#
# On malloc: sticking with glibc. jemalloc+balanced-decay was evaluated
# and costs ~15% throughput on this workload (aiohttp + PyTorch small-
# alloc density). Instead we bound memory growth via gunicorn's
# `--max-requests` so workers recycle every N requests (see entrypoint).
RUN apt-get update && apt-get install -y --no-install-recommends \
      poppler-utils \
      libgl1 \
      libglib2.0-0 \
      gettext-base \
      curl \
      g++ \
      && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install torch CPU-only from PyTorch's dedicated index. The default
# torch wheel on PyPI declares hard deps on nvidia-cuda-*, nvidia-cudnn-*,
# nvidia-nccl-* (~5 GB) that we never touch — LAYOUT_DEVICE=cuda was
# evaluated on this 8 GB dev card and the VRAM contention with SGLang
# cost more than the layout speedup gained (see phase-probe notes).
# Pre-installing `+cpu` satisfies glmocr's torch requirement so pip
# does not re-resolve it from PyPI on the next step.
RUN pip install \
      --index-url https://download.pytorch.org/whl/cpu \
      "torch>=2.2,<3" \
      "torchvision>=0.17,<1"

# Now install glmocr and friends. pip sees torch is already satisfied and
# skips the CUDA-inclusive wheel.
# onnxruntime + onnx + onnxscript power the optional LAYOUT_BACKEND=onnx
# path — a raw torch.onnx.export of PP-DocLayoutV3 gives ~1.76× on CPU
# vs eager torch. We avoid `optimum` because it pins transformers<5 while
# glmocr needs 5.5.4 for the `pp_doclayout_v3` model type.
RUN pip install \
      "glmocr[selfhosted,server]" \
      "gunicorn>=21.2,<23" \
      "psutil>=5.9" \
      "pyyaml>=6" \
      "prometheus-flask-exporter>=0.23" \
      "prometheus-client>=0.19" \
      "onnxruntime>=1.18" \
      "onnx>=1.16" \
      "onnxscript>=0.1" \
      "fastapi>=0.100,<1" \
      "uvicorn[standard]>=0.30,<1"

COPY export_layout_onnx.py /app/export_layout_onnx.py

COPY wsgi.py /app/wsgi.py
COPY runtime_app.py /app/runtime_app.py
COPY layout_postprocess.py /app/layout_postprocess.py
COPY async_app.py /app/async_app.py
COPY gunicorn_conf.py /app/gunicorn_conf.py
COPY config.yaml.template /app/config.yaml.template
COPY config.layout-off.template /app/config.layout-off.template
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 5002

# Invoke via `bash` explicitly (PATH lookup) so we don't depend on the
# script's exec bit surviving a Windows checkout, or on the shebang being
# parseable when the file picks up CRLF line endings. Same rationale as the
# sglang service in docker-compose.yml.
ENTRYPOINT ["bash", "/app/entrypoint.sh"]
