{
  "family": "glmocr-cpu",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "${EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "glmocr-cpu",
      "image": "${CPU_IMAGE_URI}",
      "essential": true,
      "portMappings": [
        {"containerPort": 5002, "hostPort": 5002, "protocol": "tcp", "name": "http"}
      ],
      "environment": [
        {"name": "CPU_WORKERS",            "value": "${CPU_WORKERS}"},
        {"name": "CPU_THREADS",            "value": "${CPU_THREADS}"},
        {"name": "GUNICORN_TIMEOUT",       "value": "${GUNICORN_TIMEOUT}"},
        {"name": "GLMOCR_PORT",            "value": "5002"},
        {"name": "OCR_MAX_WORKERS",        "value": "${OCR_MAX_WORKERS}"},
        {"name": "OCR_CONNECT_TIMEOUT",    "value": "${OCR_CONNECT_TIMEOUT}"},
        {"name": "OCR_REQUEST_TIMEOUT",    "value": "${OCR_REQUEST_TIMEOUT}"},
        {"name": "OCR_RETRY_MAX",          "value": "${OCR_RETRY_MAX}"},
        {"name": "OCR_RETRY_BACKOFF_BASE", "value": "${OCR_RETRY_BACKOFF_BASE}"},
        {"name": "OCR_RETRY_BACKOFF_MAX",  "value": "${OCR_RETRY_BACKOFF_MAX}"},
        {"name": "OCR_CONN_POOL",          "value": "${OCR_CONN_POOL}"},
        {"name": "OCR_MODEL_NAME",         "value": "${OCR_MODEL_NAME}"},
        {"name": "LAYOUT_ENABLED",         "value": "${LAYOUT_ENABLED}"},
        {"name": "LAYOUT_DEVICE",          "value": "${LAYOUT_DEVICE}"},
        {"name": "LAYOUT_USE_POLYGON",     "value": "${LAYOUT_USE_POLYGON}"},
        {"name": "SGLANG_HOST",            "value": "sglang.glmocr.local"},
        {"name": "SGLANG_PORT",            "value": "30000"},
        {"name": "SGLANG_SCHEME",          "value": "http"}
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:5002/health || curl -fsS -o /dev/null http://localhost:5002/ || exit 1"],
        "interval": 10,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/glmocr-cpu",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "glmocr-cpu",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
